{
  "name": "@querry-kit/nuxt-ui",
  "version": "1.0.0",
  "description": "Customizable Nuxt UI table components for Query Kit",
  "keywords": [
    "nuxt",
    "nuxt-ui",
    "vue",
    "table",
    "data-table",
    "filtering",
    "sorting",
    "pagination",
    "query-kit",
    "querry-kit"
  ],
  "license": "MIT",
  "homepage": "https://querry-kit.github.io/nuxt-ui/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/querry-kit/nuxt-ui.git"
  },
  "bugs": {
    "url": "https://github.com/querry-kit/nuxt-ui/issues"
  },
  "author": {
    "name": "Tobias Wälde",
    "email": "business@tobiaswaelde.com",
    "url": "https://tobiaswaelde.com"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "import": "./dist/module.mjs"
    },
    "./locales": {
      "types": "./dist/runtime/locales/index.d.ts",
      "import": "./dist/runtime/locales/index.js"
    }
  },
  "main": "./dist/module.mjs",
  "types": "./dist/module.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "dev": "nuxt-module-build build --stub",
    "prepare": "nuxt-module-build build --stub && husky",
    "prepack": "pnpm build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev:storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "screenshots:capture": "playwright test -c playwright.config.ts",
    "screenshots:check": "pnpm build:storybook && pnpm screenshots:capture && pnpm screenshots:verify",
    "screenshots:update": "pnpm build:storybook && pnpm exec playwright test -c playwright.config.ts --update-snapshots && pnpm screenshots:verify",
    "screenshots:verify": "node scripts/verify-screenshots.mjs"
  },
  "peerDependencies": {
    "@nuxt/ui": "^4.0.0",
    "@querry-kit/nuxt": "^0.0.2",
    "@tanstack/table-core": "^8.0.0",
    "@vueuse/core": "^14.0.0",
    "nuxt": "^4.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@nuxt/module-builder": "^1.0.1",
    "@nuxt/kit": "^4.4.0",
    "@nuxt/schema": "^4.4.0",
    "@playwright/test": "^1.58.2",
    "@nuxt/ui": "^4.10.0",
    "@querry-kit/nuxt": "^0.0.2",
    "@vitejs/plugin-vue": "^6.0.0",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/vue3-vite": "^10.5.2",
    "@tanstack/table-core": "^8.21.3",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "happy-dom": "^18.0.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "nuxt": "^4.4.0",
    "prettier": "^3.0.0",
    "prettier-plugin-organize-imports": "^4.0.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "storybook": "^10.5.2",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitepress": "^1.6.0",
    "vite": "^8.1.5",
    "vue-i18n": "^11.4.6",
    "vitest": "^3.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^3.0.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.15.1"
}
